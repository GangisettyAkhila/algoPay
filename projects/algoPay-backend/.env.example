# AlgoPay Backend Environment Configuration

# Algorand Node Configuration
ALGOD_TOKEN=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
ALGOD_SERVER=http://localhost
ALGOD_PORT=4001

# Backend Wallet Mnemonic (for signing transactions)
# WARNING: Never commit this to version control!
BACKEND_MNEMONIC=your 25-word mnemonic here

# Rule Engine Configuration (amounts in ALGO)
MAX_PER_TRANSACTION=1000
MAX_DAILY=10000

# Allowed Recipients (comma-separated Algorand addresses, empty = allow all)
ALLOWED_RECIPIENTS=
